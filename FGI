#!/data/data/com.termux/files/usr/bin/python
# FGI - Wrapper pour module compilé
# Reproduit le comportement de if __name__ == "__main__"

import os
import sys
from pathlib import Path

# Se placer dans le bon répertoire
os.chdir(Path(__file__).parent)

try:
    # Importer le module compilé
    import FGI
    
    # Vérifier la fonction approval() comme dans le script original
    if hasattr(FGI, 'approval') and FGI.approval():
        print("✅ Approval OK, lancement du menu...")
        print("-" * 40)
        
        # Exécuter menu() comme dans le script original
        if hasattr(FGI, 'menu'):
            try:
                FGI.menu()
            except Exception as e:
                if "ConnectionError" in str(e) or "connection" in str(e).lower():
                    print('\n No internet connection ...')
                else:
                    print(f'\n Erreur: {e}')
        else:
            print("❌ Fonction menu() non trouvée!")
    else:
        print("❌ Approval échoué ou fonction non trouvée")
        
except ImportError as e:
    print(f"❌ Erreur d'import: {e}")
    print("Assurez-vous que FGI.so est dans le même répertoire")
    sys.exit(1)
